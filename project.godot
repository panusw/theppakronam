; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Theppakronam"
config/description="Tower of Convergence — survival-craft + gacha + ATB combat RPG"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
SupabaseClient="*res://scripts/autoload/SupabaseClient.gd"
TimeManager="*res://scripts/autoload/TimeManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
CharacterColors="*res://scripts/autoload/CharacterColors.gd"
GachaEngine="*res://scripts/systems/GachaEngine.gd"
StatCalculator="*res://scripts/systems/StatCalculator.gd"
SkillTreeGraph="*res://scripts/systems/SkillTreeGraph.gd"
ToastManager="*res://scripts/ui/ToastManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[internationalization]

locale/translations=PackedStringArray("res://locale/th.th.translation", "res://locale/th.en.translation")
locale/fallback="th"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
